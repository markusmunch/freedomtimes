# Example local development env file for Terraform
# Copy to .env.dev and fill real values

TF_VAR_cloudflare_api_token=<cloudflare-api-token>
TF_VAR_cloudflare_account_id=<cloudflare-account-id>
TF_VAR_cloudflare_zone_id=<cloudflare-zone-id>
TF_VAR_route_pattern=example.com/*
TF_VAR_manage_apex_dns_record=true
TF_VAR_apex_dns_record_content=192.0.2.1

# Optional page content overrides
TF_VAR_worker_name=freedomtimes-holding
TF_VAR_holding_title=Freedom Times
TF_VAR_holding_heading=Freedom Times
TF_VAR_holding_message=We are preparing the site. Please check back soon.
TF_VAR_build_revision=
TF_VAR_contact_email=

# Auth0 — Terraform provider credentials (M2M app)
# See NON_TERRAFORM_RESOURCES.md for setup instructions
TF_VAR_auth0_domain=<auth0-tenant>.uk.auth0.com
TF_VAR_auth0_client_id=<freedomtimes-terraform M2M client-id>
TF_VAR_auth0_client_secret=<freedomtimes-terraform M2M client-secret>

# Auth0 application credentials for Worker runtime login flow
# Staging and production each use their own Regular Web App client secret.
AUTH0_LOGIN_APP_CLIENT_ID_STAGING=<freedomtimes-staging app client-id>
AUTH0_LOGIN_APP_CLIENT_SECRET_STAGING=<freedomtimes-staging app client-secret>
AUTH0_LOGIN_APP_CLIENT_ID_PRODUCTION=<freedomtimes-production app client-id>
AUTH0_LOGIN_APP_CLIENT_SECRET_PRODUCTION=<freedomtimes-production app client-secret>
