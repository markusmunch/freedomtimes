# Example shared local env file
# Copy to .env.dev and fill real values
# Environment-specific overrides belong in .env.staging and .env.production

# HCP Terraform user token lives in %APPDATA%\terraform.d\credentials.tfrc.json.
# The sync script reads it from there automatically.

# [github-secrets]
# Azure credentials for Terraform azurerm provider
ARM_CLIENT_ID=<azure-service-principal-client-id>
ARM_CLIENT_SECRET=<azure-service-principal-client-secret>
ARM_SUBSCRIPTION_ID=<azure-subscription-id>
ARM_TENANT_ID=<azure-tenant-id>

# Cloudflare provider secrets
TF_VAR_cloudflare_api_token=<cloudflare-api-token>
TF_VAR_cloudflare_account_id=<cloudflare-account-id>
TF_VAR_cloudflare_zone_id=<cloudflare-zone-id>

# Auth0 Terraform provider credentials (M2M app)
TF_VAR_auth0_domain=<auth0-tenant>.uk.auth0.com
TF_VAR_auth0_management_client_id=<freedomtimes-terraform M2M client-id>
TF_VAR_auth0_management_client_secret=<freedomtimes-terraform M2M client-secret>

# [github-vars]
# Shared Terraform defaults
TF_VAR_azure_location=uksouth
TF_VAR_route_pattern=example.com/*
TF_VAR_worker_name=freedomtimes-holding
TF_VAR_holding_title=Freedom Times
TF_VAR_holding_heading=Freedom Times
TF_VAR_holding_message=We are preparing the site. Please check back soon.
TF_VAR_contact_email=

# Shared runtime defaults
COOKIE_BASE_DOMAIN=example.com
AUTH0_ROLES_CLAIM_NAMESPACE=https://example.com
API_UPSTREAM_MODE=apim
TF_VAR_route_pattern=freedomtimes.news/*
TF_VAR_holding_message=Coming soon...
COOKIE_BASE_DOMAIN=freedomtimes.news
AUTH0_ROLES_CLAIM_NAMESPACE=https://freedomtimes.news
AUTH0_DOMAIN=freedomtimes.uk.auth0.com
AUTH0_CLIENT_ID=<dev-app-client-id>
AUTH0_CLIENT_SECRET=<dev-app-client-secret>
AUTH0_API_AUDIENCE=https://api.freedomtimes.news
API_BASE_URL=https://staging-api.freedomtimes.news

