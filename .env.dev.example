# Freedom Times - Local Development Environment Template
# 
# DO NOT commit the actual .env.dev file. Use this as a template.
# Copy this file to .env.dev and fill in with actual values.
#
# Variables below are automatically synced to GitHub Actions by scripts/set-github-secrets.ps1
# See ENVIRONMENT_SETUP.md "Syncing Secrets & Variables" for categorization details.

# ============================================
# Shared Secrets (Cloudflare, Auth0)
# ============================================

# Cloudflare API
TF_VAR_CLOUDFLARE_API_TOKEN=cfat_<your-token>
TF_VAR_CLOUDFLARE_ACCOUNT_ID=<account-id>
TF_VAR_CLOUDFLARE_ZONE_ID=<zone-id>

# Auth0 Management API
TF_VAR_AUTH0_DOMAIN=freedomtimes.uk.auth0.com
TF_VAR_AUTH0_MANAGEMENT_CLIENT_ID=<management-client-id>
TF_VAR_AUTH0_MANAGEMENT_CLIENT_SECRET=<management-client-secret>

# Turso provider auth for Terraform-managed EmDash databases
TURSO_TOKEN=<turso-api-token>

# ============================================
# Staging Secrets (Auth0 Login App, EmDash)
# ============================================

AUTH0_LOGIN_APP_CLIENT_ID_STAGING=<client-id>
AUTH0_LOGIN_APP_CLIENT_SECRET_STAGING=<client-secret>
EMDASH_AUTH_SECRET_STAGING=<auth-secret>
EMDASH_PREVIEW_SECRET_STAGING=<preview-secret>
ANDROID_STAGING_SIGNING_KEYSTORE_BASE64=<base64-jks-or-keystore>
ANDROID_STAGING_SIGNING_STORE_PASSWORD=<android-signing-store-password>
ANDROID_STAGING_SIGNING_KEY_ALIAS=<android-signing-key-alias>
ANDROID_STAGING_SIGNING_KEY_PASSWORD=<android-signing-key-password>

# ============================================
# Production Secrets (Auth0 Login App, EmDash)
# ============================================

AUTH0_LOGIN_APP_CLIENT_ID_PRODUCTION=<client-id>
AUTH0_LOGIN_APP_CLIENT_SECRET_PRODUCTION=<client-secret>
EMDASH_AUTH_SECRET_PRODUCTION=<auth-secret>
EMDASH_PREVIEW_SECRET_PRODUCTION=<preview-secret>
ANDROID_PRODUCTION_SIGNING_KEYSTORE_BASE64=<base64-jks-or-keystore>
ANDROID_PRODUCTION_SIGNING_STORE_PASSWORD=<android-signing-store-password>
ANDROID_PRODUCTION_SIGNING_KEY_ALIAS=<android-signing-key-alias>
ANDROID_PRODUCTION_SIGNING_KEY_PASSWORD=<android-signing-key-password>

# ============================================
# Shared Variables (Terraform, Auth0, App)
# ============================================

API_UPSTREAM_MODE=apim
AUTH0_API_AUDIENCE=https://api.freedomtimes.news
COOKIE_BASE_DOMAIN=freedomtimes.news
AUTH0_ROLES_CLAIM_NAMESPACE=https://freedomtimes.news/roles
TF_VAR_TURSO_ORGANIZATION=<turso-organization-slug>

# ============================================
# Optional Turso Database Overrides
# Terraform creates the database URL and app token automatically.
# ============================================

TF_VAR_TURSO_DATABASE_NAME_STAGING=freedomtimes-emdash-staging
TF_VAR_TURSO_DATABASE_NAME_PRODUCTION=freedomtimes-emdash-production
# TF_VAR_TURSO_DATABASE_GROUP_STAGING=<group-name>
# TF_VAR_TURSO_DATABASE_GROUP_PRODUCTION=<group-name>
# TF_VAR_TURSO_DATABASE_TOKEN_EXPIRATION_STAGING=8760h
# TF_VAR_TURSO_DATABASE_TOKEN_EXPIRATION_PRODUCTION=8760h
# TF_VAR_TURSO_DATABASE_SIZE_LIMIT_STAGING=10
# TF_VAR_TURSO_DATABASE_SIZE_LIMIT_PRODUCTION=10

# Scheduler Turso database connection details from Terraform outputs
TURSO_STAGING_SCHEDULER_DB_URL=<scheduler-libsql-url>
TURSO_STAGING_SCHEDULER_DB_TOKEN=<scheduler-app-token>

# Subscriptions Turso database connection details from Terraform outputs
TURSO_STAGING_SUBSCRIPTIONS_DB_URL=<subscriptions-libsql-url>
TURSO_STAGING_SUBSCRIPTIONS_DB_TOKEN=<subscriptions-app-token>

# Staging public VAPID key exposed to the web client for browser PushManager.subscribe
PUSH_STAGING_SUBSCRIBE_PUBLIC_KEY=<base64url-vapid-public-key>
PUSH_STAGING_VAPID_PRIVATE_KEY=<base64url-vapid-private-key>
PUSH_STAGING_VAPID_SUBJECT=mailto:platform@freedomtimes.news
PUSH_STAGING_ANDROID_FCM_PROJECT_ID=<firebase-project-id>
PUSH_STAGING_ANDROID_FCM_CLIENT_EMAIL=<firebase-service-account-email>
PUSH_STAGING_ANDROID_FCM_PRIVATE_KEY=<firebase-service-account-private-key-with-escaped-newlines>
PUSH_STAGING_ANDROID_GOOGLE_SERVICES_JSON_BASE64=<base64-google-services-json>
PUSH_STAGING_IOS_APNS_TEAM_ID=<apple-team-id>
PUSH_STAGING_IOS_APNS_KEY_ID=<apple-apns-key-id>
PUSH_STAGING_IOS_APNS_PRIVATE_KEY=<apple-apns-private-key-with-escaped-newlines>
PUSH_STAGING_IOS_APNS_BUNDLE_ID=news.freedomtimes.app

# Production VAPID delivery keys
PUSH_PRODUCTION_SUBSCRIBE_PUBLIC_KEY=<base64url-vapid-public-key>
PUSH_PRODUCTION_VAPID_PRIVATE_KEY=<base64url-vapid-private-key>
PUSH_PRODUCTION_VAPID_SUBJECT=mailto:platform@freedomtimes.news
PUSH_PRODUCTION_ANDROID_FCM_PROJECT_ID=<firebase-project-id>
PUSH_PRODUCTION_ANDROID_FCM_CLIENT_EMAIL=<firebase-service-account-email>
PUSH_PRODUCTION_ANDROID_FCM_PRIVATE_KEY=<firebase-service-account-private-key-with-escaped-newlines>
PUSH_PRODUCTION_ANDROID_GOOGLE_SERVICES_JSON_BASE64=<base64-google-services-json>
PUSH_PRODUCTION_IOS_APNS_TEAM_ID=<apple-team-id>
PUSH_PRODUCTION_IOS_APNS_KEY_ID=<apple-apns-key-id>
PUSH_PRODUCTION_IOS_APNS_PRIVATE_KEY=<apple-apns-private-key-with-escaped-newlines>
PUSH_PRODUCTION_IOS_APNS_BUNDLE_ID=news.freedomtimes.app

# ============================================
# Staging Variables (DNS, Routing, Domains)
# ============================================

TF_VAR_ROUTE_PATTERN_STAGING=staging.freedomtimes.news/*
TF_VAR_WORKER_NAME_STAGING=freedomtimes-holding-staging
TF_VAR_MANAGE_APEX_DNS_RECORD_STAGING=false
TF_VAR_APEX_DNS_RECORD_CONTENT_STAGING=192.0.2.1
TF_VAR_WORKSPACE_URL_STAGING=https://staging.freedomtimes.news
TF_VAR_API_MANAGEMENT_ALLOWED_ORIGINS_STAGING=https://staging.freedomtimes.news,https://freedomtimes.news
AUTH0_API_AUDIENCE_STAGING=https://api-staging.freedomtimes.news

# ============================================
# Production Variables (DNS, Routing, Domains)
# ============================================

TF_VAR_ROUTE_PATTERN_PRODUCTION=freedomtimes.news/*
TF_VAR_WORKER_NAME_PRODUCTION=freedomtimes-holding
TF_VAR_MANAGE_APEX_DNS_RECORD_PRODUCTION=true
TF_VAR_APEX_DNS_RECORD_CONTENT_PRODUCTION=192.0.2.1
TF_VAR_WORKSPACE_URL_PRODUCTION=https://freedomtimes.news
TF_VAR_API_MANAGEMENT_ALLOWED_ORIGINS_PRODUCTION=https://freedomtimes.news
AUTH0_API_AUDIENCE_PRODUCTION=https://api.freedomtimes.news

# ============================================
# Terraform Cloud (Local Only - Not Synced)
# ============================================

TF_TOKEN_app_terraform_io=<terraform-cloud-token>

