            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "children": [
          {
            "_type": "span",
            "text": "I deny him the possibility of having been a father.",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "children": [
          {
            "_type": "span",
            "text": "</details>",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "children": [
          {
            "_type": "span",
            "text": "On 8 April 2026 the same paper dated a follow-on under this headline:",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "blockquote",
        "children": [
          {
            "_type": "span",
            "text": "« Les hommes de la rue du Bac  -  après le choc »",
            "marks": []
          }
        ]
      },
      {
        "_type": "block",
        "style": "normal",
        "children": [
          {
            "_type": "span",
            "text": "<details class=\"translate\">",
            "marks": []
