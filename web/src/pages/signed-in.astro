---
import Layout from '../layouts/Layout.astro';
import { SESSION_COOKIE, getAuthConfig, getDisplayName, hasAdminRole, verifyIdToken } from '../lib/auth';

const token = Astro.cookies.get(SESSION_COOKIE)?.value;
if (!token) {
  return Astro.redirect('/');
}

let name = '';

try {
  const payload = await verifyIdToken(token, getAuthConfig());
  if (!hasAdminRole(payload)) {
    Astro.cookies.delete(SESSION_COOKIE, { path: '/' });
    return Astro.redirect('/');
  }

  name = getDisplayName(payload);
} catch {
  Astro.cookies.delete(SESSION_COOKIE, { path: '/' });
  return Astro.redirect('/');
}
---

<Layout>
  <section class="card">
    <h1>Signed in!</h1>
    <p class="lead">Welcome, {name}.</p>
    <a class="button" href="/auth/logout">Log out</a>
  </section>
</Layout>

<style>
  .card {
    width: min(640px, 94vw);
    padding: 2.5rem 2rem;
    border: 1px solid #c6bfae;
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.85);
    box-shadow: 0 18px 40px rgba(45, 39, 25, 0.14);
    text-align: center;
  }

  h1 {
    margin: 0;
    font-size: clamp(2rem, 6vw, 3rem);
  }

  .lead {
    margin: 0.9rem 0 1.4rem;
    font-size: 1.05rem;
  }

  .button {
    display: inline-block;
    padding: 0.78rem 1.2rem;
    border-radius: 999px;
    background: #7a1a1a;
    color: #ffffff;
    text-decoration: none;
    font-weight: 700;
  }

  .button:hover {
    background: #591313;
  }
</style>
