---
import { getEmDashCollection } from 'emdash';

import Layout from '../layouts/Layout.astro';
import NotificationPermission from '../components/NotificationPermission';
import { requireEditorialSession } from '../lib/editorial-session';

type Story = {
  slug: string;
  title: string;
  dek: string | null;
  imageSrc: string | null;
  status: string | null;
  updatedAt: string | null;
};

function isLikelyNativeShellRequest(request: Request): boolean {
  const userAgent = request.headers.get('user-agent')?.toLowerCase() ?? '';
  return userAgent.includes('; wv') || userAgent.includes(' version/4.0');
}

function readImageSrc(value: unknown): string | null {
  if (typeof value === 'string') {
    const trimmed = value.trim();
    return trimmed.length > 0 ? trimmed : null;
  }

  if (value && typeof value === 'object') {
    const candidate = value as Record<string, unknown>;
    if (typeof candidate.src === 'string' && candidate.src.trim().length > 0) {
      return candidate.src;
    }
    if (typeof candidate.url === 'string' && candidate.url.trim().length > 0) {
      return candidate.url;
    }
  }

  return null;
}

const session = await requireEditorialSession({
  cookies: Astro.cookies,
  url: Astro.url,
  request: Astro.request,
  redirect: Astro.redirect,
});

if (session instanceof Response) {
  return session;
}

const name = session.displayName;
const showWebNotificationPanel = !isLikelyNativeShellRequest(Astro.request);

const { entries: postEntries, error: postsError } = await getEmDashCollection('posts', {
  status: 'published',
  limit: 12,
  orderBy: { published_at: 'desc', updated_at: 'desc' },
});

if (postsError) {
  throw postsError;
}

const stories: Story[] = postEntries.map((entry) => {
  const data = entry.data as Record<string, unknown>;

  const slug = typeof data.slug === 'string' && data.slug.length > 0
    ? data.slug
    : entry.id;

  const title = typeof data.title === 'string' && data.title.length > 0
    ? data.title
    : 'Untitled post';

  const dek = typeof data.excerpt === 'string' && data.excerpt.length > 0
    ? data.excerpt
    : null;

  const imageSrc = readImageSrc(data.featured_image);

  const status = typeof data.status === 'string' ? data.status : null;
  const updatedAt = typeof data.updatedAt === 'string' ? data.updatedAt : null;

  return {
    slug,
    title,
    dek,
    imageSrc,
    status,
    updatedAt,
  };
});

const lead = stories[0] ?? null;
const secondLead = stories[1] ?? null;
const rails = stories.slice(2);
---

<Layout>
  <div class="paper-wrap">
    <header class="masthead">
      <p class="edition">London | Tuesday Edition | Investigations & Public Interest</p>
      <h1>Freedom Times</h1>
      <p class="tagline">The national paper of record for cult power, public money, and manufactured truth.</p>
      <nav>
        <a href="/homepage">Home</a>
        <a href="#">Britain</a>
        <a href="#">Investigations</a>
        <a href="#">Media</a>
        <a href="#">Business</a>
        <a href="/_emdash/admin">CMS</a>
        <a href="/auth/logout">Sign out</a>
      </nav>
      <p class="welcome">Signed in as {name}</p>
    </header>

    {showWebNotificationPanel && <NotificationPermission client:load />}

    <main class="front-grid">
      {lead ? (
        <>
          <article class="lead">
            {lead.imageSrc && <img class="story-image" src={lead.imageSrc} alt={lead.title} loading="lazy" decoding="async" />}
            <p class="kicker">{lead.status ?? 'Published'}</p>
            <h2><a href={`/posts/${lead.slug}`}>{lead.title}</a></h2>
            {lead.dek && <p>{lead.dek}</p>}
            <p class="meta">{lead.updatedAt ? `Updated ${new Date(lead.updatedAt).toLocaleString()}` : 'Published story'}</p>
          </article>

          <article class="secondary">
            {secondLead ? (
              <>
                {secondLead.imageSrc && <img class="story-image" src={secondLead.imageSrc} alt={secondLead.title} loading="lazy" decoding="async" />}
                <p class="kicker">{secondLead.status ?? 'Published'}</p>
                <h3><a href={`/posts/${secondLead.slug}`}>{secondLead.title}</a></h3>
                {secondLead.dek && <p>{secondLead.dek}</p>}
                <p class="meta">{secondLead.updatedAt ? `Updated ${new Date(secondLead.updatedAt).toLocaleString()}` : 'Published story'}</p>
              </>
            ) : (
              <>
                <p class="kicker">Newsroom</p>
                <h3>Only one published post is available right now.</h3>
                <p>Publish another post in EmDash to populate this slot.</p>
              </>
            )}
          </article>

          <section class="rail">
            {rails.length > 0 ? (
              rails.map((story) => (
                <article>
                  {story.imageSrc && <img class="story-image" src={story.imageSrc} alt={story.title} loading="lazy" decoding="async" />}
                  <p class="kicker">{story.status ?? 'Published'}</p>
                  <h4><a href={`/posts/${story.slug}`}>{story.title}</a></h4>
                  {story.dek && <p>{story.dek}</p>}
                </article>
              ))
            ) : (
              <article>
                <p class="kicker">Newsroom</p>
                <h4>No additional published posts yet.</h4>
              </article>
            )}
          </section>
        </>
      ) : (
        <article class="lead" style="grid-column: 1 / -1;">
          <p class="kicker">Newsroom</p>
          <h2>No published posts yet.</h2>
          <p>Publish posts in EmDash and they will appear here automatically.</p>
        </article>
      )}
    </main>
  </div>
</Layout>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Bodoni+Moda:opsz,wght@6..96,600;6..96,700&family=Source+Serif+4:opsz,wght@8..60,400;8..60,500;8..60,700&display=swap');

  :global(.shell) {
    display: block;
    padding: 0;
  }

  :global(body) {
    background:
      radial-gradient(circle at 20% 0%, #f5ecdc 0%, transparent 44%),
      repeating-linear-gradient(
        90deg,
        rgba(40, 28, 17, 0.02) 0,
        rgba(40, 28, 17, 0.02) 1px,
        transparent 1px,
        transparent 34px
      ),
      #f1e7d5;
    color: #1d1712;
    font-family: 'Source Serif 4', Georgia, serif;
  }

  .paper-wrap {
    max-width: 1180px;
    margin: 0 auto;
    padding: 1.2rem 1.2rem 2rem;
  }

  .masthead {
    border-bottom: 3px double #2e2418;
    padding-bottom: 0.9rem;
    animation: reveal 500ms ease-out;
  }

  .edition,
  .tagline {
    margin: 0;
    text-align: center;
    font-size: 0.82rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    text-align: center;
    font-family: 'Bodoni Moda', 'Times New Roman', serif;
    font-size: clamp(2.4rem, 7vw, 5.4rem);
    line-height: 1;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .tagline {
    margin-top: 0.35rem;
    margin-bottom: 0.8rem;
    font-size: 0.74rem;
  }

  nav {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
    padding-top: 0.5rem;
    font-weight: 700;
    font-size: 0.92rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  nav a {
    color: #1d1712;
    text-decoration: none;
  }

  .welcome {
    text-align: center;
    margin: 0.7rem 0 0;
    font-size: 0.84rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .front-grid {
    display: grid;
    grid-template-columns: 2fr 1.3fr 1.1fr;
    gap: 1.1rem;
    margin-top: 1rem;
    align-items: start;
  }

  .lead,
  .secondary,
  .rail article {
    background: linear-gradient(170deg, #faf5ea 0%, #efe3cf 100%);
    border: 1px solid #2e2418;
    padding: 0.95rem;
  }

  .story-image {
    width: 100%;
    height: auto;
    display: block;
    margin-bottom: 0.7rem;
    border: 1px solid #3a2d20;
    background: #f4ecdd;
  }

  .lead h2 {
    font-family: 'Bodoni Moda', 'Times New Roman', serif;
    font-size: clamp(1.8rem, 3.2vw, 2.6rem);
    line-height: 1.08;
    margin: 0.25rem 0 0.5rem;
  }

  .lead a,
  .secondary a,
  .rail a {
    color: #1d1712;
    text-decoration-color: #7f5d2d;
    text-underline-offset: 0.12em;
  }

  .lead a:visited,
  .secondary a:visited,
  .rail a:visited {
    color: #1d1712;
  }

  .lead a:hover,
  .secondary a:hover,
  .rail a:hover {
    color: #742312;
  }

  .secondary h3,
  .rail h4 {
    font-family: 'Bodoni Moda', 'Times New Roman', serif;
    line-height: 1.18;
    margin: 0.2rem 0 0.4rem;
  }

  .secondary h3 {
    font-size: 1.5rem;
  }

  .rail {
    display: grid;
    gap: 0.7rem;
  }

  .rail h4 {
    font-size: 1.17rem;
  }

  .kicker {
    margin: 0;
    font-weight: 700;
    font-size: 0.74rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #742312;
  }

  .meta {
    margin-bottom: 0;
    font-size: 0.82rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  @keyframes reveal {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 960px) {
    .front-grid {
      grid-template-columns: 1fr;
    }

    .paper-wrap {
      padding-left: 0.75rem;
      padding-right: 0.75rem;
    }

    nav {
      justify-content: flex-start;
    }
  }
</style>
