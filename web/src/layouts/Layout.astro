---
import Footer from '../components/Footer.astro';
import { SITE_DISPLAY_NAME } from '../lib/site-brand';
import '../styles/global.css';

interface Props {
	hideFooter?: boolean;
	title?: string;
	description?: string;
	twitterDescription?: string | null;
	canonicalUrl?: string;
	ogType?: 'website' | 'article';
	ogImage?: string | null;
	ogImageWidth?: number;
	ogImageHeight?: number;
	ogImageAlt?: string;
	socialTitle?: string;
	twitterTitle?: string | null;
	publishedTime?: string | null;
	modifiedTime?: string | null;
	author?: string | null;
	noindex?: boolean;
}

const siteName = SITE_DISPLAY_NAME;
const defaultDescription = `Independent reporting, investigations, and analysis from ${SITE_DISPLAY_NAME}.`;
const {
	hideFooter = false,
	title,
	description,
	twitterDescription,
	canonicalUrl,
	ogType = 'website',
	ogImage,
	ogImageWidth = 1200,
	ogImageHeight = 630,
	ogImageAlt,
	socialTitle,
	twitterTitle,
	publishedTime,
	modifiedTime,
	author,
	noindex = false,
} = Astro.props as Props;

const resolvedTitle = title?.trim().length ? `${title.trim()} | ${siteName}` : siteName;
const resolvedSocialTitle = socialTitle?.trim().length ? socialTitle.trim() : resolvedTitle;
const resolvedTwitterTitle = twitterTitle === null
	? null
	: (twitterTitle !== undefined ? twitterTitle : resolvedSocialTitle);
const resolvedDescription = description?.trim().length ? description.trim() : defaultDescription;
const resolvedTwitterDescription = twitterDescription === null
	? null
	: (twitterDescription !== undefined ? twitterDescription : resolvedDescription);
const resolvedCanonicalUrl = canonicalUrl?.trim().length ? canonicalUrl.trim() : Astro.url.href;
const absoluteCanonical = new URL(resolvedCanonicalUrl, Astro.url).toString();
const absoluteOgImage = ogImage?.trim().length ? new URL(ogImage.trim(), Astro.url).toString() : null;
const resolvedOgImageAlt = ogImageAlt?.trim().length ? ogImageAlt.trim() : `${siteName} share preview`;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" href="/favicon.ico" sizes="any" />
		<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/manifest.webmanifest" />
		<meta name="theme-color" content="#1d4b3e" />
		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-title" content={SITE_DISPLAY_NAME} />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={resolvedDescription} />
		<meta name="robots" content={noindex ? 'noindex,nofollow' : 'index,follow,max-image-preview:large'} />
		<link rel="canonical" href={absoluteCanonical} />
		<meta property="og:site_name" content={siteName} />
		<meta property="og:type" content={ogType} />
		<meta property="og:title" content={resolvedSocialTitle} />
		<meta property="og:description" content={resolvedDescription} />
		<meta property="og:url" content={absoluteCanonical} />
		{absoluteOgImage && <meta property="og:image" content={absoluteOgImage} />}
		{absoluteOgImage && <meta property="og:image:secure_url" content={absoluteOgImage} />}
		{absoluteOgImage && <meta property="og:image:alt" content={resolvedOgImageAlt} />}
		{absoluteOgImage && <meta property="og:image:width" content={String(ogImageWidth)} />}
		{absoluteOgImage && <meta property="og:image:height" content={String(ogImageHeight)} />}
		{ogType === 'article' && publishedTime && <meta property="article:published_time" content={publishedTime} />}
		{ogType === 'article' && modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
		{ogType === 'article' && author && <meta property="article:author" content={author} />}
		<meta name="twitter:card" content={absoluteOgImage ? 'summary_large_image' : 'summary'} />
		{resolvedTwitterTitle === '' && <meta name="twitter:title" content="" />}
		{resolvedTwitterTitle !== null && resolvedTwitterTitle !== '' && (
			<meta name="twitter:title" content={resolvedTwitterTitle} />
		)}
		{resolvedTwitterDescription !== null && <meta name="twitter:description" content={resolvedTwitterDescription} />}
		{absoluteOgImage && <meta name="twitter:image" content={absoluteOgImage} />}
		{absoluteOgImage && <meta name="twitter:image:alt" content={resolvedOgImageAlt} />}
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,800;0,900;1,400;1,700&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,500;0,8..60,600;0,8..60,700;1,8..60,400;1,8..60,700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
		<title>{resolvedTitle}</title>
	</head>
	<body>
		<main class="shell">
			<slot />
		</main>
		<script>
			import { initializeNativeAuthBridge } from '../lib/native-auth-bridge';
			import { initializeNativePushBridge } from '../lib/device-notifications';
			import { initializePwa } from '../lib/pwa';

			void initializeNativeAuthBridge();
			void initializeNativePushBridge();
			void initializePwa();
		</script>
		{!hideFooter && <Footer />}
	</body>
</html>
