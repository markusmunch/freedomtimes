---
/**
 * Portable Text block `_type: "video"` — YouTube, generic video iframes, or `<video>` for direct files.
 * Use `Audio.astro` for podcast / radio iframe embeds and native `<audio>`.
 */
const props = Astro.props as Record<string, unknown>;
const value =
	(props.value as Record<string, unknown> | undefined)
	?? (props.node as Record<string, unknown> | undefined)
	?? props;

function readString(input: unknown): string | null {
	return typeof input === 'string' && input.trim().length > 0 ? input.trim() : null;
}

function readAspectRatio(input: unknown): string | null {
	if (typeof input !== 'string') {
		return null;
	}
	const trimmed = input.trim();
	if (!trimmed) {
		return null;
	}
	// Accept CSS aspect-ratio forms like "16 / 9", "4/3", "1.91 / 1".
	if (/^\d+(?:\.\d+)?\s*\/\s*\d+(?:\.\d+)?$/.test(trimmed)) {
		return trimmed.replace(/\s*\/\s*/, ' / ');
	}
	return null;
}

function resolveVideoUrl(input: unknown): string | null {
	if (!input || typeof input !== 'object') {
		return null;
	}

	const candidate = input as Record<string, unknown>;
	const directUrl =
		readString(candidate.url)
		?? readString(candidate.file)
		?? readString((candidate.asset as Record<string, unknown> | undefined)?._ref)
		?? readString((candidate.asset as Record<string, unknown> | undefined)?.id)
		?? readString(candidate._ref)
		?? readString(candidate.id);

	if (!directUrl) {
		return null;
	}

	if (directUrl.startsWith('/')) {
		return directUrl;
	}

	if (directUrl.startsWith('http://') || directUrl.startsWith('https://')) {
		try {
			const parsed = new URL(directUrl);
			if (parsed.pathname.startsWith('/_emdash/api/media/file/')) {
				return parsed.pathname;
			}
			return parsed.toString();
		} catch {
			return null;
		}
	}

	return `/_emdash/api/media/file/${directUrl}`;
}

/** 11-char IDs are typical; allow shorter documented test IDs. */
const YOUTUBE_ID = /^[A-Za-z0-9_-]{6,}$/;

/**
 * Resolve a watch/share/embed/Shorts URL to a video id. CMS often stores
 * `watch?t=…&v=…` or full `embed/…` URLs — the old `watch?v=`–only regex missed those
 * and treated YouTube as a generic iframe (blank / wrong).
 */
function youtubeVideoIdFromUrl(url: string): string | null {
	try {
		const u = new URL(url);
		const host = u.hostname.toLowerCase().replace(/^www\./, '');
		if (host === 'youtu.be') {
			const id = u.pathname.split('/').filter(Boolean)[0] ?? '';
			return YOUTUBE_ID.test(id) ? id : null;
		}
		const isYoutube =
			host === 'youtube.com' ||
			host === 'm.youtube.com' ||
			host === 'youtube-nocookie.com';
		if (!isYoutube) {
			return null;
		}
		const v = u.searchParams.get('v');
		if (v && YOUTUBE_ID.test(v)) {
			return v;
		}
		const parts = u.pathname.split('/').filter(Boolean);
		if (parts[0] === 'embed' && parts[1] && YOUTUBE_ID.test(parts[1])) {
			return parts[1];
		}
		if (parts[0] === 'shorts' && parts[1] && YOUTUBE_ID.test(parts[1])) {
			return parts[1];
		}
		return null;
	} catch {
		return null;
	}
}

const src = resolveVideoUrl(value);
const alt = readString(value.alt) ?? 'Embedded video';
const aspectRatio = readAspectRatio(value.aspectRatio) ?? '16 / 9';
const youtubeId = src ? youtubeVideoIdFromUrl(src) : null;
const youtubeEmbedSrc = youtubeId ? `https://www.youtube.com/embed/${youtubeId}` : null;
const isDirectMediaFile = !!src?.match(/\.(mp4|webm|ogg|m3u8)(\?.*)?$/i) || src?.startsWith('/_emdash/api/media/file/');
const genericEmbedSrc = !youtubeEmbedSrc && !isDirectMediaFile ? src : null;
---

{src && (
	<figure class="video-embed" style={`--video-aspect-ratio: ${aspectRatio};`}>
		{youtubeEmbedSrc ? (
			<iframe
				src={youtubeEmbedSrc}
				title={alt}
				loading="lazy"
				allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
				allowfullscreen
			></iframe>
		) : genericEmbedSrc ? (
			<iframe
				src={genericEmbedSrc}
				title={alt}
				loading="lazy"
				allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
				allowfullscreen
			></iframe>
		) : (
			<video controls preload="metadata" src={src} aria-label={alt}></video>
		)}
	</figure>
)}
