---
import { readOptionalEnv } from '../lib/auth';
import { SITE_DISPLAY_NAME } from '../lib/site-brand';

interface Props {
	section?: string;
	sectionUrl?: string;
	isEditor?: boolean;
	isSignedIn?: boolean;
}

const { section, sectionUrl, isEditor, isSignedIn } = Astro.props;
const siteAccessMode = readOptionalEnv('SITE_ACCESS_MODE').trim().toLowerCase();
const homePath = siteAccessMode === 'public' ? '/' : '/homepage';
---

<header class="masthead">
	<p class="edition">UK & Europe | Investigations & Public Interest</p>
	<div class="brand-wrap">
		<a href={homePath}><h1>{SITE_DISPLAY_NAME}</h1></a>
	</div>
	<p class="tagline">Telling survivor truths. Protecting sources. Holding cults to account.</p>
	
	<nav class="main-nav">
		<div class="nav-links">
			<a href={homePath} class={Astro.url.pathname === '/' || Astro.url.pathname === '/homepage' ? 'active' : ''}>Home</a>
			<a href="/archives" class={Astro.url.pathname.startsWith('/archives') ? 'active' : ''}>Archives</a>
			{isEditor && <a href="/_emdash/admin">CMS</a>}
			{isSignedIn && <a href="/auth/logout">Sign out</a>}
		</div>
		
		{section && (
			<div class="breadcrumbs">
				<span class="sep">/</span>
				<a href={sectionUrl || '#'}>{section}</a>
			</div>
		)}
	</nav>
</header>

<style>
	.masthead {
		max-width: var(--max-width-main);
		margin: 0 auto 3rem;
		border-bottom: 1px solid #111111;
		padding: var(--page-padding-top) var(--page-padding-side) 2rem;
		text-align: left;
	}

	.edition {
		margin: 0 0 1.5rem;
		font-family: 'Inter', sans-serif;
		font-size: 0.85rem;
		font-weight: 700;
		letter-spacing: 0.05em;
		color: #555555;
	}

	.brand-wrap a {
		text-decoration: none;
		color: inherit;
	}

	h1 {
		margin: 0 0 1rem;
		font-family: 'Playfair Display', serif;
		font-size: clamp(2.5rem, 7vw, 4.5rem);
		font-weight: 900;
		line-height: 1;
		letter-spacing: -0.015em;
	}

	.tagline {
		margin: 0 0 2rem;
		max-width: 800px;
		font-family: 'Source Serif 4', serif;
		font-size: 1.15rem;
		font-style: italic;
		color: #333333;
		line-height: 1.4;
	}

	nav.main-nav {
		display: flex;
		align-items: center;
		justify-content: flex-start;
		gap: 2rem;
		padding: 1.25rem 0;
		border-top: 1px solid #eeeeee;
		border-bottom: 1px solid #eeeeee;
		font-family: 'Inter', sans-serif;
		font-weight: 600;
		font-size: 0.95rem;
		letter-spacing: 0.02em;
	}

	.nav-links {
		display: flex;
		gap: 2rem;
	}

	.nav-links a {
		color: #111111;
		text-decoration: none;
		transition: color 0.2s ease;
	}

	.nav-links a:hover,
	.nav-links a.active {
		color: #0044bb;
	}

	.breadcrumbs {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		color: #999999;
	}

	.breadcrumbs a {
		color: #0044bb;
		text-decoration: none;
	}

	.sep {
		font-weight: 400;
		color: #dddddd;
	}

	@media (max-width: 768px) {
		h1 {
			font-size: 3.5rem;
		}
		nav.main-nav {
			flex-direction: column;
			gap: 0.5rem;
		}
	}
</style>
