---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Video from '../components/Video.astro';
import Audio from '../components/Audio.astro';
import PortableLink from '../components/PortableLink.astro';
import PushNotificationsCallout from './PushNotificationsCallout.astro';
import EntryHeader from './content/EntryHeader.astro';
import EntryMedia from './content/EntryMedia.astro';
import EntryBody from './content/EntryBody.astro';
import { readOptionalEnv } from '../lib/auth';
import {
	buildPortableRenderNodes,
	parseLegacyTextContent,
} from '../lib/content/contentBlocks';
import {
	buildContentEntryViewModel,
	readEntrySeoRecord,
	resolveSocialImageSrc,
} from '../lib/content/contentEntry';
import { SITE_DISPLAY_NAME } from '../lib/site-brand';

const {
	entry,
	collectionLabel,
	emdashCollection,
	displayName,
	isPreview = false,
	isEditor = false,
	isSignedIn,
} = Astro.props as {
	entry: { id: string; slug?: string; data: Record<string, unknown> };
	collectionLabel: string;
	/** EmDash collection slug (`posts`, `pages`, `archives`, …) for `_emdash_seo` OG lookup */
	emdashCollection: string;
	displayName: string;
	isPreview?: boolean;
	isEditor?: boolean;
	isSignedIn?: boolean;
};

const siteAccessMode = readOptionalEnv('SITE_ACCESS_MODE').trim().toLowerCase();
const resolvedIsSignedIn = isSignedIn ?? siteAccessMode !== 'public';
const {
	title,
	summaryParagraphs,
	portableContent,
	textContent,
	featuredImageSrc,
	featuredImageAlt,
	volumeNumber,
	regionalVariant,
	pageImages,
	slidePageNumbers,
	slidePageTotal,
	pdfLink,
	subjectChips,
	issueDate,
	publishedAt,
	updatedAt,
	primaryByline,
} = buildContentEntryViewModel(entry as { slug?: string; data: Record<string, unknown> } & Record<string, unknown>);
const entryRecord = entry as Record<string, unknown>;
const seoRecord = readEntrySeoRecord(entryRecord);
const socialImageSrc = await resolveSocialImageSrc(entry.data, seoRecord, {
	origin: Astro.url.origin,
	emdashSeoLookup: {
		collection: emdashCollection,
		contentId: String(entry.id ?? ''),
		slug: typeof entry.slug === 'string' ? entry.slug : undefined,
	},
});
const portableComponents = {
	type: {
		video: Video,
		audio: Audio,
	},
	mark: {
		link: PortableLink,
	},
};

const legacyBlocks = textContent ? parseLegacyTextContent(textContent) : [];
const portableRenderNodes = buildPortableRenderNodes(portableContent);
const description = summaryParagraphs[0] ?? `Read "${title}" on ${SITE_DISPLAY_NAME}.`;
const canonicalPath = collectionLabel === 'Archive' ? `/archives/${entry.slug ?? entry.id}` : `/posts/${entry.slug ?? entry.id}`;
const publicationDate = publishedAt
	? new Date(publishedAt)
	: null;
const publicationDateLabel =
	publicationDate && Number.isFinite(publicationDate.getTime())
		? publicationDate.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' })
		: null;
const socialTitle = publicationDateLabel ? `${title} - ${publicationDateLabel}` : title;
---

<Layout
	title={title}
	socialTitle={socialTitle}
	description={description}
	canonicalUrl={canonicalPath}
	ogType="article"
	ogImage={socialImageSrc ?? null}
	ogImageWidth={1200}
	ogImageHeight={675}
	ogImageAlt={socialImageSrc ? socialTitle : undefined}
	publishedTime={publishedAt}
	modifiedTime={updatedAt}
	author={primaryByline}
>
	<article class="page-wrap">
		<Header section={collectionLabel} sectionUrl={collectionLabel === 'Archive' ? '/archives' : '/homepage'} isEditor={isEditor} isSignedIn={resolvedIsSignedIn} />

		<EntryHeader
			title={title}
			issueDate={issueDate}
			primaryByline={primaryByline}
			publishedAt={publishedAt}
			updatedAt={updatedAt}
			isPreview={isPreview}
			subjectChips={subjectChips}
		/>

		<section class="content-card">
			<EntryMedia
				title={title}
				pageImages={pageImages}
				slidePageNumbers={slidePageNumbers}
				slidePageTotal={slidePageTotal}
				volumeNumber={volumeNumber}
				regionalVariant={regionalVariant}
				pdfLink={pdfLink}
				featuredImageSrc={featuredImageSrc}
				featuredImageAlt={featuredImageAlt}
			/>
			<EntryBody
				portableRenderNodes={portableRenderNodes}
				portableContent={portableContent}
				textContent={textContent}
				legacyBlocks={legacyBlocks}
				portableComponents={portableComponents}
			/>
			<PushNotificationsCallout />
		</section>
	</article>
</Layout>

<style>

	.page-wrap {
		max-width: var(--max-width-article);
		margin: 0 auto;
		padding: 0 var(--page-padding-side) 5rem;
	}

	:global(.legacy-details) {
		margin: 1.25rem 0;
		padding: 0.85rem 1rem;
		border: 1px solid #d8d8d8;
		border-radius: 8px;
		background: #f7f7f7;
	}

	:global(.legacy-details summary) {
		cursor: pointer;
		font-family: 'Inter', sans-serif;
		font-weight: 600;
	}

	:global(.legacy-details p) {
		margin: 0.9rem 0 0;
	}

	/* Translation fold-out: not a blockquote (no left bar); keep distinct from body copy. */
	:global(.legacy-details.translate),
	:global(.legacy-details.translation) {
		border-left: none;
	}

	:global(.article-header h1) {
		margin: 0;
		font-family: 'Playfair Display', serif;
		font-size: clamp(2.5rem, 7vw, 4.5rem);
		font-weight: 900;
		line-height: 1;
		letter-spacing: -0.01em;
	}

	:global(.issue-date) {
		margin: 1rem 0 0;
		font-family: 'Inter', sans-serif;
		font-size: 0.85rem;
		font-weight: 600;
		letter-spacing: 0.05em;
		color: #333333;
	}


	:global(.article-header) {
		margin-bottom: 2.5rem;
		border-bottom: 1px solid #eeeeee;
		padding-bottom: 2rem;
	}

	:global(.article-meta) {
		display: flex;
		gap: 1.5rem;
		margin-top: 1rem;
		font-family: 'Inter', sans-serif;
		font-size: 0.75rem;
		color: #777777;
		letter-spacing: 0.05em;
	}

	:global(.article-meta p) {
		margin: 0;
	}

	:global(.subject-list) {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		list-style: none;
		padding: 0;
		margin: 1rem 0 0;
	}

	:global(.subject-list li) {
		font-family: 'Inter', sans-serif;
		font-size: 0.7rem;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		font-weight: 700;
		padding: 0.3rem 0.5rem;
		border: 1px solid var(--subject-chip-border, #dddddd);
		background: var(--subject-chip-bg, #fafafa);
		color: var(--subject-chip-text, #333333);
	}

	:global(.preview) {
		color: #cc0000;
		font-weight: 700;
	}

	.content-card {
		line-height: 1.7;
		font-size: 1.15rem;
	}

	:global(.hero) {
		margin: 0 0 3rem;
	}

	:global(.hero img) {
		display: block;
		width: 100%;
		height: auto;
		border: 1px solid #eeeeee;
	}

	:global(.slideshow) {
		margin: 0 0 4rem;
		padding: 2rem;
		background: #fcfcfc;
		border: 1px solid #eeeeee;
	}

	:global(.slideshow-header) {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 1.5rem;
		font-family: 'Inter', sans-serif;
		letter-spacing: 0.1em;
	}

	:global(.slideshow-kicker) {
		margin: 0;
		font-size: 0.8rem;
		font-weight: 700;
		color: #0044bb;
	}

	:global(.edition-meta) {
		margin: 0;
		font-size: 0.75rem;
		color: #777777;
	}

	:global(.slideshow-frame-wrap) {
		display: grid;
		grid-template-columns: auto minmax(0, 1fr) auto;
		gap: 1.5rem;
		align-items: center;
	}

	:global(.slideshow-frame) {
		position: relative;
		min-height: 400px;
		background: #ffffff;
		box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
		border: 1px solid #eeeeee;
	}

	:global(.slide) {
		position: absolute;
		inset: 0;
		opacity: 0;
		transition: opacity 0.3s ease;
		margin: 0;
	}

	:global(.slide.is-active) {
		opacity: 1;
		position: relative;
	}

	:global(.slide img) {
		display: block;
		width: 100%;
		height: auto;
	}

	:global(.slide-nav) {
		background: #ffffff;
		border: 1px solid #dddddd;
		color: #111111;
		padding: 0.75rem 1rem;
		font-family: 'Inter', sans-serif;
		font-weight: 700;
		font-size: 0.7rem;
		letter-spacing: 0.1em;
		cursor: pointer;
		transition: all 0.2s ease;
	}

	:global(.slide-nav:hover) {
		background: #111111;
		color: #ffffff;
		border-color: #111111;
	}

	:global(.slide-status) {
		margin: 1.5rem 0 0;
		text-align: center;
		font-family: 'Inter', sans-serif;
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 0.1em;
	}

	:global(.pdf-link-wrap) {
		margin: 1.5rem 0 0;
		text-align: center;
	}

	:global(.pdf-link-wrap a) {
		font-family: 'Inter', sans-serif;
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 0.05em;
		color: #0044bb;
		text-decoration: none;
	}

	:global(.pdf-link-wrap a:hover) {
		text-decoration: underline;
	}

	/* One column measure for PT + legacy body: headings, embeds, and paragraphs share the same edge. */
	.content-card :global(.portable-content),
	.content-card :global(.legacy-content) {
		max-width: 65ch;
	}

	.content-card :global(p) {
		margin: 0 0 1.5rem;
		max-width: 65ch;
	}

	.content-card :global(h2),
	.content-card :global(h3),
	.content-card :global(h4) {
		font-family: 'Playfair Display', serif;
		font-weight: 800;
		line-height: 1.2;
		margin: 3rem 0 1rem;
	}

	.content-card :global(a) {
		color: #0044bb;
		text-decoration: underline;
		text-decoration-thickness: 1px;
		text-underline-offset: 3px;
	}

	.content-card :global(blockquote) {
		margin: 2rem 0;
		padding: 1rem 1.25rem;
		max-width: 65ch;
		border-left: 4px solid #111111;
		background: #f8f8f8;
	}

	.content-card :global(blockquote p) {
		margin: 0;
		font-family: 'Source Serif 4', serif;
		font-style: italic;
		color: #1f1f1f;
	}

	.content-card :global(.video-embed) {
		margin: 2rem 0;
		max-width: 65ch;
	}

	.content-card :global(.video-embed video) {
		display: block;
		width: 100%;
		height: auto;
		border: 1px solid #eeeeee;
		background: #000000;
	}

	.content-card :global(.video-embed iframe) {
		display: block;
		width: 100%;
		aspect-ratio: var(--video-aspect-ratio, 16 / 9);
		border: 1px solid #eeeeee;
		background: #000000;
	}

	@media (max-width: 768px) {
		.page-wrap {
			padding: 2rem 1rem;
		}
		.masthead {
			grid-template-columns: 1fr;
			gap: 1rem;
		}
		.meta-block {
			align-items: flex-start;
			text-align: left;
		}
		nav {
			justify-content: flex-start;
		}
		:global(.slideshow-frame-wrap) {
			grid-template-columns: 1fr;
		}
		:global(.slide-nav) {
			width: 100%;
		}
	}
</style>

<script>
	import { initContentEnhancements } from '../lib/content/contentEnhancements';

	initContentEnhancements();
</script>
