# Local dev secrets for cult-columnist-cf-worker (--env local)
# Copy this file to .dev.vars and fill in real values.
# .dev.vars is gitignored — never commit it.

AUTH0_DOMAIN=freedomtimes.us.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# Optional Stage 1 API adapter (non-RSS/XML)
NEWSDATA_ENABLED=false
NEWSDATA_API_KEY=
# Alias also supported:
# NEWSIO_API_KEY=
# Optional overrides:
# NEWSDATA_COUNTRY_CODES=gb,ie,fr,de,es,it,nl,be,at,ch,se,no,dk,fi,pl,pt,ro,cz,gr,hr,si,hu,sk
# NEWSDATA_LANGUAGES=en
# NEWSDATA_QUERY_LIMIT=10
# NEWSDATA_TIMEFRAME_HOURS=24
