# Must remain staging while this agent is under validation.
AGENT_ENV=staging

# Comma-separated list of allowed source hostnames.
ALLOWED_SOURCE_HOSTS=culteducation.com,cultnews.net,cultnews101.com,thetimes.co.uk,telegraph.co.uk,dailyrecord.co.uk,dailymail.co.uk,thesun.co.uk,mirror.co.uk,bbc.com,theguardian.com,reuters.com,apnews.com,ft.com,politico.eu,euobserver.com,dw.com,lemonde.fr,elpais.com

# In this starter, only dry-run output is implemented.
DRY_RUN=true

# Required runtime input: discovery freshness window in hours.
# Weekly runs should use 168.
DISCOVERY_MAX_AGE_HOURS=168

# Watchlist: each publisher gets its own dedicated query by default (chunk=1) to avoid cross-publisher RSS slot competition.
# Increase e.g. to 3 or 6 if query count becomes a runtime concern, but this risks missing stories from lower-volume publishers.
# GOOGLE_NEWS_WATCHLIST_SITE_OR_CHUNK=1

# Cluster expansion caps: `0` or unset = unlimited (all qualifying phrases / stories).
# CLUSTER_EXPANSION_MAX_CLUSTERS=0
# CLUSTER_EXPANSION_MAX_QUERIES_PER_CLUSTER=0
# CLUSTER_EXPANSION_MAX_TOTAL_QUERIES=0
# CLUSTER_EXPANSION_SINGLETON_MAX_STORIES=0

# After main discovery, optional second Google News pass from shared title phrases (needs ≥3 strong stories).
# CLUSTER_EXPANSION_MIN_CLUSTER_SIZE=3

# When fewer than CLUSTER_EXPANSION_MIN_CLUSTER_SIZE strong stories exist, still run a follow-up pass
# from title phrases on each high-scoring story (“cluster of one”). Disable with false.
# CLUSTER_EXPANSION_SINGLETON_ENABLED=true

# Google News runs each search query once per European locale edition (gl/hl/ceid).
# Optional comma-separated locale ids to restrict (see discoverStories.ts EUROPE_GOOGLE_NEWS_LOCALES), e.g. FR-fr,DE-de
GOOGLE_NEWS_LOCALE_IDS=

# Optional cap on total Google News RSS discoveries per run (deduped URLs). `0` = unlimited (default).
# GOOGLE_NEWS_TOTAL_CAP=0

# After fetch+decode, try Playwright navigation for links still on news.google.com (slower; serialised).
# GOOGLE_NEWS_RESOLVE_USE_PLAYWRIGHT=false
# Max Playwright navigations per full discovery run (`0` = unlimited when enabled).
# GOOGLE_NEWS_PLAYWRIGHT_MAX_RESOLVES=0

# Pacing for Google News RSS (reduces 503/429). Extra pause after each 503.
# GOOGLE_NEWS_RSS_REQUEST_GAP_MS=200
# GOOGLE_NEWS_RSS_AFTER_503_MS=5000

# Optional: Google News time token appended to every RSS q= (e.g. when:7d). If unset, derived from
# DISCOVERY_MAX_AGE_HOURS as when:Nh (e.g. 168 → when:168h). Set to off/none/false to disable.
GOOGLE_NEWS_WHEN=

# Optional structured discovery provider (consumes API credits per request).
NEWSDATA_ENABLED=false
NEWSIO_API_KEY=
# Optional cap on NewsData API credits consumed per run (default 6).
NEWSIO_MAX_CREDITS_PER_RUN=6

# HeadlineFeed discovery (https://headlinefeed.dev) — title-only whole-word search, max 7-day window.
# Searches one term per API request (cult, sect, brainwashing, trafficking, slavery, etc.).
HEADLINEFEED_ENABLED=false
HEADLINEFEED_API_KEY=
# Cache TTL for HeadlineFeed results in minutes (default 360 = 6 hours).
# HEADLINEFEED_CACHE_TTL_MINUTES=360

# Optional runtime input for week-ending focus parameters (no hardcoding in source).
# Provide either inline JSON...
# DISCOVERY_FOCUS_JSON={"focusSignalTerms":["jehovah's witnesses","ruling"],"googleNewsGenericQueries":["\"religious ruling\" norway"]}
# ...or a path to a JSON file containing the same shape.
DISCOVERY_FOCUS_JSON=
DISCOVERY_FOCUS_FILE=

# Optional: HTTP fetch retries for transient errors (503, etc.) — see http-cache/config.ts.
# HTTP_FETCH_MAX_ATTEMPTS=4
# HTTP_FETCH_RETRY_BASE_MS=800
# HTTP_FETCH_RETRY_MAX_MS=90000
# HTTP_FETCH_RETRYABLE_STATUS_CODES=408,429,502,503,504
# HTTP_FETCH_RETRY_NETWORK_ERRORS=true

# Per-cell fetch lifecycle: fetch-start → fetch-done, plus postprocess-start → resolve-link-progress → postprocess-done
# when the RSS feed lacks direct article URLs (default on). Set false to reduce log volume.
# DISCOVERY_LOG_GOOGLE_NEWS_FETCH_LIFECYCLE=true

# Write reports/google-news-query-plan-latest.json (and timestamped copy) before each main Google News pass.
# GOOGLE_NEWS_RECORD_QUERY_PLAN=true
# Include full locale id list on every query row (very large JSON; rssCells is always present).
# GOOGLE_NEWS_QUERY_PLAN_INCLUDE_LOCALE_IDS=false
# Log every N Google News link resolutions after RSS parse (1 = each link).
# DISCOVERY_PROGRESS_GOOGLE_NEWS_LINK_RESOLVE_EVERY=5

# Parallel article link fetches after each RSS response (deduped by URL; bounded).
# GOOGLE_NEWS_LINK_RESOLVE_CONCURRENCY=8
# Lookahead window = CONCURRENCY × this multiplier (smaller = less speculative work if you cap early).
# GOOGLE_NEWS_LINK_PREFETCH_MULT=4

# Log every Google News RSS HTTP round-trip (request→response, incl. retries): timings + attempts.
# DISCOVERY_LOG_EVERY_GOOGLE_NEWS_HTTP=false

# Optional: how often [agent][progress] logs fire (defaults shown).
# DISCOVERY_PROGRESS_GOOGLE_NEWS_EVERY=10
# DISCOVERY_PROGRESS_FEEDS_EVERY=5
# PIPELINE_PROGRESS_EVERY=5

# Reserved for future MCP integration.
CMS_MCP_BASE_URL=
CMS_MCP_TOKEN=
